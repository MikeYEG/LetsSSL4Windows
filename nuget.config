<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Ensures the public NuGet feed is available and enabled for this repo,
    regardless of machine/user NuGet settings. Restore needs internet access
    to api.nuget.org the first time (packages are then cached locally).
  -->
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <disabledPackageSources>
    <clear />
  </disabledPackageSources>
</configuration>
