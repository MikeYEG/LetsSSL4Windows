<Window x:Class="LetsSSL.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LetsSSL4Windows — Certificate Manager"
        Height="640" Width="1000"
        MinHeight="480" MinWidth="760"
        Background="{StaticResource Bg}"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="150" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}"
                BorderThickness="0,0,0,1" Padding="20,14">
            <Grid>
                <StackPanel>
                    <TextBlock Text="LetsSSL4Windows" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}" />
                    <TextBlock Text="{Binding EnvironmentDisplay}" FontSize="12"
                               Foreground="{StaticResource TextMuted}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="Toggle theme" Style="{StaticResource SecondaryButton}"
                            Click="OnToggleTheme" ToolTip="Switch between dark and light" />
                    <Button Content="Settings" Style="{StaticResource SecondaryButton}"
                            Margin="8,0,0,0" Click="OnSettings" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Toolbar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="20,14,20,8">
            <Button Content="+ New certificate" Style="{StaticResource PrimaryButton}"
                    Click="OnNewCertificate" IsEnabled="{Binding IsNotBusy}" />
            <Button Content="Renew selected" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"
                    Command="{Binding RenewSelectedCommand}" />
            <Button Content="Renew all due" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"
                    Command="{Binding RenewAllCommand}" />
            <Button Content="Bind to IIS…" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"
                    Click="OnBindToIis" ToolTip="Bind the selected certificate to an IIS site (HTTPS / SNI) without re-issuing it." />
            <Button Content="Export…" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"
                    Click="OnExport" ToolTip="Export the selected certificate as a .pfx or .pem file." />
            <Button Content="Remove" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"
                    Command="{Binding DeleteSelectedCommand}" />
            <Button Content="Refresh" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"
                    Command="{Binding RefreshCommand}" />
        </StackPanel>

        <!-- Renewal service status + monitoring -->
        <Border Grid.Row="2" Margin="20,0,20,8" Background="{StaticResource Surface}"
                BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="8" Padding="12,8">
            <StackPanel>
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="9" Height="9" Fill="{Binding ServiceStateBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="Renewal service:" FontWeight="SemiBold" Margin="8,0,4,0" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ServiceStateText}" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="Install" Style="{StaticResource SecondaryButton}" Padding="10,4"
                                Command="{Binding InstallServiceCommand}"
                                ToolTip="Register and start the background renewal service." />
                        <Button Content="Start" Style="{StaticResource SecondaryButton}" Padding="10,4" Margin="8,0,0,0"
                                Command="{Binding StartServiceCommand}" />
                        <Button Content="Stop" Style="{StaticResource SecondaryButton}" Padding="10,4" Margin="8,0,0,0"
                                Command="{Binding StopServiceCommand}" />
                    </StackPanel>
                </Grid>
                <StackPanel Orientation="Horizontal" Margin="17,6,0,0">
                    <TextBlock Text="{Binding NextExpiryText}" Foreground="{StaticResource TextMuted}" FontSize="12" />
                    <TextBlock Text="  ·  " Foreground="{StaticResource TextMuted}" FontSize="12" />
                    <TextBlock Text="{Binding LastRunText}" Foreground="{StaticResource TextMuted}" FontSize="12" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Certificate grid -->
        <Border Grid.Row="3" Margin="20,0,20,8" Background="{StaticResource Surface}"
                BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="8">
            <DataGrid ItemsSource="{Binding Certificates}"
                      SelectedItem="{Binding SelectedCertificate}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                      BorderThickness="0" Background="Transparent" RowHeight="38"
                      CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Status" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                                    <Ellipse Width="9" Height="9" Fill="{Binding StatusBrush}"
                                             VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding StatusText}" Margin="6,0,0,0"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="180" />
                    <DataGridTextColumn Header="Domains" Binding="{Binding Domains}" Width="*" />
                    <DataGridTextColumn Header="IIS site" Binding="{Binding IisSite}" Width="140" />
                    <DataGridTextColumn Header="Expires" Binding="{Binding Expiry}" Width="100" />
                    <DataGridTextColumn Header="Days left" Binding="{Binding DaysLeft}" Width="90" />
                    <DataGridTemplateColumn Header="Thumbprint" Width="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Copy" Click="OnCopyThumbprint" Tag="{Binding Thumbprint}"
                                        Style="{StaticResource SecondaryButton}" Padding="10,3" FontSize="11"
                                        Margin="8,0" HorizontalAlignment="Left" VerticalAlignment="Center"
                                        ToolTip="{Binding Thumbprint}"
                                        Visibility="{Binding HasThumbprint, Converter={StaticResource BoolToVis}}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Activity log -->
        <Border Grid.Row="4" Margin="20,0,20,8" Background="{StaticResource ConsoleBg}"
                BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="8">
            <ScrollViewer x:Name="LogScroller" VerticalScrollBarVisibility="Auto" Padding="12,8">
                <TextBlock Text="{Binding LogText}" Foreground="{StaticResource ConsoleFg}"
                           FontFamily="Consolas" FontSize="12" TextWrapping="Wrap" />
            </ScrollViewer>
        </Border>

        <!-- Update banner (shown only when a newer GitHub release exists) -->
        <Border Grid.Row="5" Background="{StaticResource Accent}" Padding="16,10"
                Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVis}}">
            <Grid>
                <TextBlock Text="{Binding UpdateBannerText}" Foreground="White"
                           FontWeight="SemiBold" VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="Download and install" Style="{StaticResource SecondaryButton}" Padding="10,4"
                            Command="{Binding DownloadInstallCommand}"
                            ToolTip="Download the installer for the new version and run it." />
                    <Button Content="Release notes" Style="{StaticResource SecondaryButton}" Padding="10,4"
                            Margin="8,0,0,0" Command="{Binding OpenReleaseCommand}" />
                    <Button Content="Dismiss" Style="{StaticResource SecondaryButton}" Padding="10,4"
                            Margin="8,0,0,0" Command="{Binding DismissUpdateCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="6" Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}"
                BorderThickness="0,1,0,0" Padding="20,8">
            <Grid>
                <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource TextMuted}"
                           VerticalAlignment="Center" />
                <ProgressBar Width="120" Height="6" IsIndeterminate="True"
                             HorizontalAlignment="Right"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
            </Grid>
        </Border>
    </Grid>
</Window>
