<Window x:Class="LetsSSL.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctl="clr-namespace:LetsSSL.App.Controls"
        Title="Settings"
        Width="520" SizeToContent="Height" MaxHeight="920"
        Background="{StaticResource Bg}"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Settings" FontSize="18" FontWeight="Bold"
                   Foreground="{StaticResource TextPrimary}" Margin="0,0,0,12" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="800" Padding="0,0,8,0">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="ACME environment" FontWeight="SemiBold" />
                    <TextBlock Style="{StaticResource InfoGlyph}"
                               ToolTip="Staging issues untrusted test certificates with high rate limits — use it first. Production issues real, browser-trusted certificates (stricter limits)." />
                </StackPanel>
                <RadioButton Content="Staging — test certificates, high rate limits (recommended first)"
                             IsChecked="{Binding IsProduction, Converter={StaticResource InverseBool}}"
                             Margin="0,0,0,4" />
                <RadioButton Content="Production — real, browser-trusted certificates"
                             IsChecked="{Binding IsProduction}" />

                <StackPanel Orientation="Horizontal" Margin="0,16,0,4">
                    <TextBlock Text="Default contact email" FontWeight="SemiBold" />
                    <TextBlock Style="{StaticResource InfoGlyph}"
                               ToolTip="Pre-fills the contact email in the New Certificate wizard and registers your Let's Encrypt account." />
                </StackPanel>
                <TextBox Text="{Binding ContactEmail, UpdateSourceTrigger=PropertyChanged}"
                         ctl:Placeholder.Text="you@example.com" />

                <CheckBox Content="Enable unattended auto-renewal (used by the renewal service)"
                          IsChecked="{Binding EnableAutoRenewal}" Margin="0,16,0,0"
                          VerticalContentAlignment="Center"
                          ToolTip="When on, the renewal service reissues certificates automatically before they expire (default: 30 days before)." />

                <StackPanel Orientation="Horizontal" Margin="0,16,0,4">
                    <TextBlock Text="Appearance" FontWeight="SemiBold" />
                    <TextBlock Style="{StaticResource InfoGlyph}"
                               ToolTip="Choose the dark or light theme. The change applies immediately and is remembered between launches." />
                </StackPanel>
                <CheckBox Content="Dark mode" IsChecked="{Binding IsDarkMode}"
                          VerticalContentAlignment="Center"
                          ToolTip="Toggle between the dark and light theme." />

                <StackPanel Orientation="Horizontal" Margin="0,16,0,4">
                    <TextBlock Text="Updates" FontWeight="SemiBold" />
                    <TextBlock Style="{StaticResource InfoGlyph}"
                               ToolTip="Checks GitHub for a newer release and can download and run the installer." />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Check for updates" Style="{StaticResource SecondaryButton}" Padding="10,4"
                            Command="{Binding CheckForUpdatesCommand}" />
                    <Button Content="Download and install" Style="{StaticResource PrimaryButton}" Padding="10,4"
                            Margin="8,0,0,0" Command="{Binding DownloadInstallCommand}"
                            Visibility="{Binding UpdateFound, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
                <TextBlock Text="{Binding UpdateCheckStatus}" Foreground="{StaticResource TextMuted}"
                           TextWrapping="Wrap" Margin="0,6,0,0" />

                <!-- Notifications -->
                <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}"
                        BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,18,0,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Notifications" FontWeight="SemiBold" />
                            <TextBlock Style="{StaticResource InfoGlyph}"
                                       ToolTip="Alerts sent when a certificate is issued/renewed, or when a renewal fails." />
                        </StackPanel>
                        <CheckBox Content="Notify on successful issuance/renewal"
                                  IsChecked="{Binding NotifyOnSuccess}" Margin="0,8,0,0"
                                  ToolTip="Send a notification each time a certificate is issued or renewed successfully." />
                        <CheckBox Content="Notify on failure" IsChecked="{Binding NotifyOnFailure}" Margin="0,4,0,0"
                                  ToolTip="Send a notification when an issuance or renewal fails — the case you most want to know about." />

                        <StackPanel Orientation="Horizontal" Margin="0,12,0,4">
                            <TextBlock Text="Webhook URL (Slack/Teams/Discord/custom)" FontWeight="SemiBold" />
                            <TextBlock Style="{StaticResource InfoGlyph}"
                                       ToolTip="A JSON payload is POSTed here for each notification. Works with Slack/Teams/Discord incoming webhooks or any custom endpoint." />
                        </StackPanel>
                        <TextBox Text="{Binding WebhookUrl, UpdateSourceTrigger=PropertyChanged}"
                                 ctl:Placeholder.Text="https://hooks.slack.com/services/..." />

                        <CheckBox Content="Send email (SMTP)" IsChecked="{Binding EmailEnabled}" Margin="0,14,0,0"
                                  ToolTip="Also deliver notifications by email through an SMTP server." />
                        <StackPanel Visibility="{Binding EmailEnabled, Converter={StaticResource BoolToVis}}"
                                    Margin="22,6,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="90" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="SMTP host" FontWeight="SemiBold" />
                                        <TextBlock Style="{StaticResource InfoGlyph}"
                                                   ToolTip="Your mail server's hostname, e.g. smtp.gmail.com or smtp.office365.com." />
                                    </StackPanel>
                                    <TextBox Text="{Binding SmtpHost, UpdateSourceTrigger=PropertyChanged}"
                                             ctl:Placeholder.Text="smtp.example.com" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Port" FontWeight="SemiBold" Margin="0,0,0,4" />
                                    <TextBox Text="{Binding SmtpPort}"
                                             ToolTip="587 for STARTTLS, 465 for SSL, 25 for plain (not recommended)." />
                                </StackPanel>
                            </Grid>
                            <CheckBox Content="Use SSL/TLS" IsChecked="{Binding SmtpUseSsl}" Margin="0,8,0,0"
                                      ToolTip="Encrypt the connection to the SMTP server (recommended)." />

                            <StackPanel Orientation="Horizontal" Margin="0,8,0,4">
                                <TextBlock Text="Username" FontWeight="SemiBold" />
                                <TextBlock Style="{StaticResource InfoGlyph}"
                                           ToolTip="SMTP login. Leave blank for servers that don't require authentication." />
                            </StackPanel>
                            <TextBox Text="{Binding SmtpUsername, UpdateSourceTrigger=PropertyChanged}"
                                     ctl:Placeholder.Text="you@example.com" />

                            <StackPanel Orientation="Horizontal" Margin="0,8,0,4">
                                <TextBlock Text="Password" FontWeight="SemiBold" />
                                <TextBlock Style="{StaticResource InfoGlyph}"
                                           ToolTip="SMTP password or app password. Stored encrypted with Windows DPAPI." />
                            </StackPanel>
                            <TextBox Text="{Binding SmtpPassword, UpdateSourceTrigger=PropertyChanged}"
                                     ctl:Placeholder.Text="Stored encrypted (DPAPI)" />

                            <StackPanel Orientation="Horizontal" Margin="0,8,0,4">
                                <TextBlock Text="From address" FontWeight="SemiBold" />
                                <TextBlock Style="{StaticResource InfoGlyph}"
                                           ToolTip="The sender address notifications are sent from." />
                            </StackPanel>
                            <TextBox Text="{Binding FromAddress, UpdateSourceTrigger=PropertyChanged}"
                                     ctl:Placeholder.Text="letsssl@example.com" />

                            <StackPanel Orientation="Horizontal" Margin="0,8,0,4">
                                <TextBlock Text="To address" FontWeight="SemiBold" />
                                <TextBlock Style="{StaticResource InfoGlyph}"
                                           ToolTip="Where notification emails are delivered." />
                            </StackPanel>
                            <TextBox Text="{Binding ToAddress, UpdateSourceTrigger=PropertyChanged}"
                                     ctl:Placeholder.Text="you@example.com" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Style="{StaticResource SecondaryButton}" Click="OnCancel" />
            <Button Content="Save" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Click="OnSave" />
        </StackPanel>
    </Grid>
</Window>
