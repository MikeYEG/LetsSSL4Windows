<Window x:Class="LetsSSL.App.Views.ManualDnsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create DNS TXT record(s)"
        Width="560" SizeToContent="Height" MaxHeight="820"
        Background="{StaticResource Bg}"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Manual DNS validation" FontSize="16" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimary}" />
            <TextBlock x:Name="IntroText" TextWrapping="Wrap" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="620" Padding="0,0,6,0">
            <ItemsControl x:Name="RecordsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="{Binding Heading}" FontWeight="Bold"
                                       Foreground="{StaticResource Accent}" Margin="0,0,0,6" />
                            <TextBlock Text="Record name (type: TXT)" FontWeight="SemiBold" Margin="0,0,0,4" />
                            <Grid>
                                <TextBox IsReadOnly="True" Text="{Binding Name, Mode=OneWay}" Padding="8,6,70,6" />
                                <Button Content="Copy" Click="OnCopy" Tag="{Binding Name}"
                                        Style="{StaticResource SecondaryButton}" Padding="8,3" FontSize="11"
                                        HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,6,0" />
                            </Grid>
                            <TextBlock Text="Record value" FontWeight="SemiBold" Margin="0,10,0,4" />
                            <Grid>
                                <TextBox IsReadOnly="True" Text="{Binding Value, Mode=OneWay}" TextWrapping="Wrap"
                                         Height="56" VerticalScrollBarVisibility="Auto" Padding="8,6,70,6" />
                                <Button Content="Copy" Click="OnCopy" Tag="{Binding Value}"
                                        Style="{StaticResource SecondaryButton}" Padding="8,3" FontSize="11"
                                        HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,6,6,0" />
                            </Grid>
                            <TextBlock Text="{Binding CheckText}" Foreground="{Binding CheckBrush}"
                                       FontSize="12" FontWeight="SemiBold" Margin="0,6,0,0" />
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="0,8,0,0">
            <TextBlock x:Name="ReadyHint" VerticalAlignment="Center" FontSize="12"
                       FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Re-check DNS" Style="{StaticResource SecondaryButton}" Click="OnRecheck"
                        Margin="0,0,8,0" />
                <Button Content="Continue" Style="{StaticResource PrimaryButton}" Click="OnContinue" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
