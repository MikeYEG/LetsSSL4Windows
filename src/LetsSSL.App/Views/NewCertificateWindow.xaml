<Window x:Class="LetsSSL.App.Views.NewCertificateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctl="clr-namespace:LetsSSL.App.Controls"
        Title="New certificate"
        Width="600"
        SizeToContent="Height" MaxHeight="940" MinHeight="380"
        Background="{StaticResource Bg}"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Request a new certificate" FontSize="18" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimary}" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="780" Padding="0,0,8,0">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="Primary domain" FontWeight="SemiBold" />
                    <TextBlock Style="{StaticResource InfoGlyph}"
                               ToolTip="The main hostname the certificate secures (its common name). Example: www.example.com. Tick Wildcard below for *.example.com." />
                </StackPanel>
                <TextBox x:Name="PrimaryDomainBox" TextChanged="OnRequiredFieldChanged"
                         Text="{Binding PrimaryDomain, UpdateSourceTrigger=PropertyChanged}"
                         ctl:Placeholder.Text="www.example.com" />
                <CheckBox Content="Wildcard certificate (*.) — covers all subdomains; uses DNS-01"
                          IsChecked="{Binding IsWildcard}" Margin="0,6,0,0"
                          VerticalContentAlignment="Center"
                          ToolTip="Issues a *.example.com certificate covering all subdomains. Wildcards require DNS-01 validation." />
                <CheckBox Content="Also cover the bare domain (needs a second DNS record)"
                          IsChecked="{Binding IncludeApexDomain}" Margin="22,4,0,0"
                          VerticalContentAlignment="Center"
                          Visibility="{Binding ShowApexOption, Converter={StaticResource BoolToVis}}"
                          ToolTip="Adds example.com alongside *.example.com. The wildcard and the bare domain validate separately, so this requires a SECOND TXT record at the same _acme-challenge name. Uncheck to need only one DNS record (the cert then won't cover example.com itself)." />

                <StackPanel Orientation="Horizontal" Margin="0,12,0,4">
                    <TextBlock Text="Additional domains (SAN) — optional" FontWeight="SemiBold" />
                    <TextBlock Style="{StaticResource InfoGlyph}"
                               ToolTip="Extra hostnames to include on the same certificate — one per line." />
                </StackPanel>
                <TextBox Text="{Binding SansText}" AcceptsReturn="True" Height="56"
                         TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         ctl:Placeholder.Text="mail.example.com&#x0a;api.example.com" />

                <StackPanel Orientation="Horizontal" Margin="0,12,0,4">
                    <TextBlock Text="Contact email" FontWeight="SemiBold" />
                    <TextBlock Style="{StaticResource InfoGlyph}"
                               ToolTip="Registers your Let's Encrypt account and receives expiry/issue notices." />
                </StackPanel>
                <TextBox x:Name="ContactEmailBox" TextChanged="OnRequiredFieldChanged"
                         Text="{Binding ContactEmail, UpdateSourceTrigger=PropertyChanged}"
                         ctl:Placeholder.Text="you@example.com" />

                <!-- Validation method -->
                <StackPanel Orientation="Horizontal" Margin="0,16,0,6">
                    <TextBlock Text="Validation method" FontWeight="SemiBold" />
                    <TextBlock Style="{StaticResource InfoGlyph}"
                               ToolTip="How you prove control of the domain. HTTP-01 serves a file over port 80; DNS-01 publishes a TXT record and is required for wildcards." />
                </StackPanel>
                <RadioButton Content="HTTP-01 — serve a file from the site (port 80 must be reachable)"
                             IsChecked="{Binding UseHttp}" Margin="0,0,0,4"
                             IsEnabled="{Binding IsWildcard, Converter={StaticResource InverseBool}}" />
                <RadioButton Content="DNS-01 — publish a TXT record (required for wildcard certificates)"
                             IsChecked="{Binding UseDns}" />

                <!-- HTTP options -->
                <StackPanel Visibility="{Binding ShowHttpOptions, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,4">
                        <TextBlock Text="Web root (for challenge files)" FontWeight="SemiBold" />
                        <TextBlock Style="{StaticResource InfoGlyph}"
                                   ToolTip="The folder served at the domain's root. The challenge file is written under \.well-known\acme-challenge\. Auto-filled from the chosen IIS site." />
                    </StackPanel>
                    <TextBox x:Name="WebRootBox" TextChanged="OnRequiredFieldChanged"
                             Text="{Binding WebRootPath, UpdateSourceTrigger=PropertyChanged}"
                             ctl:Placeholder.Text="C:\inetpub\wwwroot" />
                </StackPanel>

                <!-- DNS options -->
                <StackPanel Visibility="{Binding ShowDnsOptions, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,4">
                        <TextBlock Text="DNS provider" FontWeight="SemiBold" />
                        <TextBlock Style="{StaticResource InfoGlyph}"
                                   ToolTip="Who publishes the validation TXT record. Cloudflare does it automatically with an API token; Manual prompts you to create it by hand." />
                    </StackPanel>
                    <ComboBox ItemsSource="{Binding DnsProviders}" SelectedItem="{Binding SelectedDnsProvider}"
                              Padding="8,6">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource DnsProviderName}}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <StackPanel Visibility="{Binding ShowCloudflareToken, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,4">
                            <TextBlock Text="Cloudflare API token (Zone:DNS:Edit)" FontWeight="SemiBold" />
                            <TextBlock Style="{StaticResource InfoGlyph}"
                                       ToolTip="A Cloudflare API token with Zone:DNS:Edit on the domain's zone. Stored encrypted with Windows DPAPI." />
                        </StackPanel>
                        <TextBox x:Name="DnsApiTokenBox" TextChanged="OnRequiredFieldChanged"
                                 Text="{Binding DnsApiToken, UpdateSourceTrigger=PropertyChanged}"
                                 ctl:Placeholder.Text="Paste your Cloudflare API token" />
                    </StackPanel>

                    <!-- Route 53 (AWS) credentials -->
                    <StackPanel Visibility="{Binding ShowRoute53Fields, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,4">
                            <TextBlock Text="AWS Access Key ID" FontWeight="SemiBold" />
                            <TextBlock Style="{StaticResource InfoGlyph}"
                                       ToolTip="An IAM access key with permission to change records in the hosted zone (route53:ChangeResourceRecordSets, ListHostedZones, GetChange). Stored encrypted with Windows DPAPI." />
                        </StackPanel>
                        <TextBox x:Name="AwsAccessKeyBox" TextChanged="OnRequiredFieldChanged"
                                 Text="{Binding AwsAccessKeyId, UpdateSourceTrigger=PropertyChanged}"
                                 ctl:Placeholder.Text="AKIA..." />

                        <StackPanel Orientation="Horizontal" Margin="0,12,0,4">
                            <TextBlock Text="AWS Secret Access Key" FontWeight="SemiBold" />
                            <TextBlock Style="{StaticResource InfoGlyph}"
                                       ToolTip="The secret paired with the access key ID. Stored encrypted with Windows DPAPI." />
                        </StackPanel>
                        <TextBox x:Name="AwsSecretBox" TextChanged="OnRequiredFieldChanged"
                                 Text="{Binding AwsSecretAccessKey, UpdateSourceTrigger=PropertyChanged}"
                                 ctl:Placeholder.Text="Secret access key" />

                        <StackPanel Orientation="Horizontal" Margin="0,12,0,4">
                            <TextBlock Text="Hosted Zone ID — optional" FontWeight="SemiBold" />
                            <TextBlock Style="{StaticResource InfoGlyph}"
                                       ToolTip="The Route 53 hosted zone ID (e.g. Z1234567890ABC). Leave blank to auto-detect the zone that contains your domain." />
                        </StackPanel>
                        <TextBox Text="{Binding AwsHostedZoneId, UpdateSourceTrigger=PropertyChanged}"
                                 ctl:Placeholder.Text="Auto-detected if left blank" />
                    </StackPanel>

                    <!-- Validate the automated provider's credentials against its API. -->
                    <Button Content="Test credentials" Style="{StaticResource SecondaryButton}"
                            HorizontalAlignment="Left" Margin="0,12,0,0" Click="OnTestDnsCredentials"
                            IsEnabled="{Binding IsTestingDns, Converter={StaticResource InverseBool}}"
                            Visibility="{Binding ShowDnsCredentialTest, Converter={StaticResource BoolToVis}}"
                            ToolTip="Check the credentials against the provider's API before requesting a certificate." />
                    <TextBlock Text="{Binding DnsCredentialTestStatus}" Margin="0,6,0,0" TextWrapping="Wrap"
                               FontSize="12" Foreground="{StaticResource TextMuted}"
                               Visibility="{Binding DnsCredentialTestStatus, Converter={StaticResource NonEmptyToVis}}" />
                </StackPanel>

                <!-- IIS site(s) / binding -->
                <StackPanel Orientation="Horizontal" Margin="0,16,0,4">
                    <TextBlock Text="IIS sites (optional — for web root and binding)" FontWeight="SemiBold" />
                    <TextBlock Style="{StaticResource InfoGlyph}"
                               ToolTip="The IIS website(s) to bind the certificate to and to auto-detect the web root. Tick one or more sites, or leave all unticked if you're not using IIS." />
                </StackPanel>
                <Grid>
                    <ToggleButton x:Name="SitesDropToggle" MinHeight="34" HorizontalContentAlignment="Stretch"
                                  Background="{StaticResource SurfaceAlt}" BorderBrush="{StaticResource Border}">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="ToggleButton">
                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="1" CornerRadius="6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="24" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding SitesSummary}" Margin="10,0,0,0"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                   Foreground="{StaticResource TextPrimary}" />
                                        <Path Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Data="M 0 0 L 4 4 L 8 0 Z" Fill="{StaticResource TextMuted}" />
                                    </Grid>
                                </Border>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>
                    <Popup IsOpen="{Binding IsChecked, ElementName=SitesDropToggle}" StaysOpen="False"
                           Placement="Bottom" PlacementTarget="{Binding ElementName=SitesDropToggle}"
                           AllowsTransparency="True" PopupAnimation="Slide"
                           Width="{Binding ActualWidth, ElementName=SitesDropToggle}">
                        <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}"
                                BorderThickness="1" CornerRadius="6" Margin="0,2,0,0">
                            <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding SiteSelections}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                      Margin="10,6" VerticalContentAlignment="Center" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </Popup>
                </Grid>
                <CheckBox Content="Bind the certificate to the selected IIS site(s) (HTTPS / SNI)"
                          IsChecked="{Binding BindToIis}" Margin="0,8,0,0" VerticalContentAlignment="Center"
                          ToolTip="Adds or updates an HTTPS binding on each selected site, using SNI so multiple hosts can share port 443." />
                <CheckBox Content="Auto-renew before expiry" IsChecked="{Binding AutoRenew}"
                          Margin="0,6,0,0" VerticalContentAlignment="Center"
                          ToolTip="Lets the renewal service/agent reissue this certificate automatically before it expires (default: 30 days before)." />

                <StackPanel Orientation="Horizontal" Margin="0,12,0,4">
                    <TextBlock Text="Certificate name in IIS (friendly name) — optional" FontWeight="SemiBold" />
                    <TextBlock Style="{StaticResource InfoGlyph}"
                               ToolTip="A friendly name for the certificate as it appears in IIS's Server Certificates list. Leave blank to let IIS show the subject. Reapplied on every renewal." />
                </StackPanel>
                <TextBox Text="{Binding FriendlyName, UpdateSourceTrigger=PropertyChanged}"
                         ctl:Placeholder.Text="e.g. www.example.com (Let's Encrypt)" />

                <!-- Remote IIS servers (WinRM) -->
                <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}"
                        BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,16,0,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Remote IIS servers (WinRM) — optional" FontWeight="SemiBold" />
                            <TextBlock Style="{StaticResource InfoGlyph}"
                                       ToolTip="Deploy this certificate to other Windows/IIS servers on every renewal, over WinRM. The renewal service connects as its own identity — a domain service account that is a local admin on each target (Kerberos; no passwords are stored). Each target imports the certificate and binds the listed IIS sites." />
                        </StackPanel>
                        <ItemsControl ItemsSource="{Binding RemoteTargets}" Margin="0,8,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="6"
                                            Padding="10" Margin="0,0,0,8">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="80" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0" VerticalContentAlignment="Center"
                                                         Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}"
                                                         ctl:Placeholder.Text="web2.corp.local" />
                                                <TextBox Grid.Column="1" Margin="8,0,0,0" VerticalContentAlignment="Center"
                                                         Text="{Binding WinRmPort, UpdateSourceTrigger=PropertyChanged}"
                                                         ToolTip="WinRM port (5986 for HTTPS, 5985 for HTTP)." />
                                                <Button Grid.Column="2" Content="Test" Style="{StaticResource SecondaryButton}"
                                                        Margin="8,0,0,0" Click="OnTestRemoteTarget"
                                                        IsEnabled="{Binding IsTesting, Converter={StaticResource InverseBool}}"
                                                        ToolTip="Connect over WinRM and list the remote IIS sites." />
                                                <Button Grid.Column="3" Content="Remove" Style="{StaticResource SecondaryButton}"
                                                        Margin="8,0,0,0" Click="OnRemoveRemoteTarget" />
                                            </Grid>
                                            <TextBox Margin="0,6,0,0"
                                                     Text="{Binding SiteNamesText, UpdateSourceTrigger=PropertyChanged}"
                                                     ctl:Placeholder.Text="Remote IIS site(s), comma-separated — e.g. Default Web Site, api" />
                                            <CheckBox Content="WinRM over HTTPS (recommended)" IsChecked="{Binding UseSsl}"
                                                      Margin="0,6,0,0" VerticalContentAlignment="Center" />
                                            <TextBlock Text="{Binding TestStatus}" Margin="0,6,0,0" TextWrapping="Wrap"
                                                       FontSize="11" Foreground="{StaticResource TextMuted}"
                                                       Visibility="{Binding TestStatus, Converter={StaticResource NonEmptyToVis}}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <Button Content="+ Add remote server" Style="{StaticResource SecondaryButton}"
                                    Click="OnAddRemoteTarget" />
                            <Button Content="Test all" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"
                                    Click="OnTestAllRemoteTargets"
                                    Visibility="{Binding HasRemoteTargets, Converter={StaticResource BoolToVis}}"
                                    IsEnabled="{Binding IsTestingAll, Converter={StaticResource InverseBool}}"
                                    ToolTip="Run the WinRM pre-flight against every remote server listed above." />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Deployment tasks -->
                <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}"
                        BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,16,0,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Deployment tasks (optional)" FontWeight="SemiBold" />
                            <TextBlock Style="{StaticResource InfoGlyph}"
                                       ToolTip="Actions to run after each successful issuance/renewal." />
                        </StackPanel>
                        <CheckBox Content="Export PFX to a path" IsChecked="{Binding ExportPfxEnabled}"
                                  Margin="0,8,0,0"
                                  ToolTip="Write the issued certificate as a .pfx file to a path you choose." />
                        <StackPanel Visibility="{Binding ExportPfxEnabled, Converter={StaticResource BoolToVis}}"
                                    Margin="22,4,0,0">
                            <TextBox Text="{Binding ExportPfxPath}" Margin="0,0,0,4"
                                     ctl:Placeholder.Text="C:\certs\example.pfx" />
                            <TextBox Text="{Binding ExportPfxPassword}"
                                     ctl:Placeholder.Text="Optional PFX password" />
                        </StackPanel>
                        <CheckBox Content="Run a script after issuance" IsChecked="{Binding RunScriptEnabled}"
                                  Margin="0,10,0,0"
                                  ToolTip="Run a .ps1 or .exe after issuance. Cert details are passed via LETSSSL4WINDOWS_* environment variables." />
                        <StackPanel Visibility="{Binding RunScriptEnabled, Converter={StaticResource BoolToVis}}"
                                    Margin="22,4,0,0">
                            <TextBox Text="{Binding RunScriptPath}" Margin="0,0,0,4"
                                     ctl:Placeholder.Text="C:\deploy\reload.ps1" />
                            <TextBox Text="{Binding RunScriptArguments}"
                                     ctl:Placeholder.Text="Optional arguments" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="0,16,0,0">
            <TextBlock x:Name="ValidationMessage" Foreground="{StaticResource Danger}"
                       VerticalAlignment="Center" HorizontalAlignment="Left" TextWrapping="Wrap"
                       MaxWidth="360" FontSize="12" Visibility="Collapsed" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Style="{StaticResource SecondaryButton}" Click="OnCancel" />
                <Button Content="Request certificate" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0"
                        Click="OnSubmit" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
